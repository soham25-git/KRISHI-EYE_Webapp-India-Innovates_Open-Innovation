# Environment configuration for AI Service

ENVIRONMENT=development
LOG_LEVEL=INFO

# Networking
PORT=8000
ALLOWED_ORIGINS=http://localhost:3000,http://localhost:3001,http://localhost:8080

# Datastores
DATABASE_URL=postgresql://user:password@localhost:5432/farmer_platform
VECTOR_DB_URL=postgresql://user:password@localhost:5432/farmer_platform

# Providers (Swappable abstractions)
EMBEDDING_PROVIDER=placeholder
EMBEDDING_MODEL=placeholder-emb-v1
EMBEDDING_API_KEY=

LLM_PROVIDER=placeholder
LLM_MODEL=placeholder-llm-v1
LLM_API_KEY=

RERANK_PROVIDER=placeholder
RERANK_MODEL=placeholder-rerank-v1
RERANK_API_KEY=

# Advisory config
CONFIDENCE_THRESHOLD=0.7
ABSTENTION_THRESHOLD=0.4

# Versioning & Traceability
PROMPT_VERSION=v1.0.0
KNOWLEDGE_VERSION=v1.0.0
